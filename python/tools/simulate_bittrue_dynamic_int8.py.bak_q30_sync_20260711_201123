from __future__ import annotations

import argparse
import json
import math
import pickle
import sys
from pathlib import Path
from typing import Any

import numpy as np
import torch
import torch.nn.functional as F


NANOGPT_ROOT = Path(__file__).resolve().parents[1]
REPO_ROOT = NANOGPT_ROOT.parent
if str(NANOGPT_ROOT) not in sys.path:
    sys.path.insert(0, str(NANOGPT_ROOT))

from tools.eval_int8_reference import load_checkpoint_model, load_torch  # noqa: E402


SEQ_LEN = 256
D_MODEL = 384
N_HEAD = 6
HEAD_DIM = 64


def quant_dynamic(x: np.ndarray) -> tuple[np.ndarray, float]:
    max_abs = float(np.max(np.abs(x.astype(np.float64))))
    scale = max(max_abs / 127.0, float(np.finfo(np.float32).eps))
    q = np.clip(np.rint(x.astype(np.float64) / scale), -128, 127).astype(np.int8)
    return q, scale


def quant_fixed(x: np.ndarray, scale: float) -> np.ndarray:
    return np.clip(np.rint(x.astype(np.float64) / float(scale)), -128, 127).astype(np.int8)


def round_div_signed_array(values: np.ndarray, denominator: int) -> np.ndarray:
    wide = values.astype(np.int64)
    rounded = (np.abs(wide) + denominator // 2) // denominator
    return np.where(wide < 0, -rounded, rounded)


def compare_i8(reference: np.ndarray, candidate: np.ndarray) -> dict[str, Any]:
    ref = reference.astype(np.int16).reshape(-1)
    cand = candidate.astype(np.int16).reshape(-1)
    diff = np.abs(ref - cand)
    return {
        "mismatch": int(np.count_nonzero(diff)),
        "elements": int(diff.size),
        "mean_abs_error": float(diff.mean()),
        "max_abs_error": int(diff.max(initial=0)),
        "within_1_ratio": float(np.mean(diff <= 1)),
    }


class BitTrueModel:
    def __init__(self, checkpoint: Path, int8_state: Path, dataset: str):
        self.fp32_model, self.checkpoint = load_checkpoint_model(checkpoint)
        self.state = load_torch(int8_state, map_location="cpu")
        self.modules = self.state["modules"]
        with (NANOGPT_ROOT / "data" / dataset / "meta.pkl").open("rb") as handle:
            meta = pickle.load(handle)
        self.stoi = meta["stoi"]
        self.itos = meta["itos"]
        gelu_scales = [
            float(module["activation_scale"])
            for name, module in self.modules.items()
            if "mlp.c_fc" in name and module.get("activation_scale") is not None
        ]
        self.gelu_scale = float(np.median(gelu_scales))
        xs = torch.arange(-128, 128, dtype=torch.float32) * self.gelu_scale
        lut = torch.clamp(torch.round(F.gelu(xs) / self.gelu_scale), -128, 127).to(torch.int8)
        self.gelu_lut = lut.cpu().numpy().astype(np.int8)
        hardware_root = (
            REPO_ROOT / "fpga" / "nano_gpt" / "generated" / "int8_alignment" / "hardware_params"
        )
        hardware_manifest = json.loads((hardware_root / "manifest.json").read_text(encoding="utf-8"))
        self.hardware_manifest = hardware_manifest
        self.attention_score_q16 = np.asarray(
            hardware_manifest["attention_score_q16"], dtype=np.int64
        )
        self.attention_out_mult_q30 = np.asarray(
            hardware_manifest["attention_out_mult_q30"], dtype=np.int64
        )
        exp_path = (
            REPO_ROOT
            / "fpga"
            / "nano_gpt"
            / "generated"
            / "int8_quality_hw_exact_s256_d384_l6"
            / "luts"
            / "attn_exp_neg_q6_q4.mem"
        )
        self.attention_exp_q6 = np.asarray(
            [int(line, 16) & 0x3F for line in exp_path.read_text(encoding="ascii").splitlines() if line],
            dtype=np.int64,
        )
        self.layernorm_coeff_q24 = np.fromfile(
            hardware_root / "layernorm_coeff_q24.bin", dtype="<i4"
        ).astype(np.int64).reshape(13, D_MODEL)
        self.lm_scale_ratio_q30 = np.fromfile(
            hardware_root / "lm_head_scale_ratio_q30.bin", dtype="<u4"
        ).astype(np.int64)
        self.q_mult_q30 = np.fromfile(hardware_root / "q_mult_q30.bin", dtype="<u4").astype(np.int64).reshape(6, D_MODEL)
        self.k_mult_q30 = np.fromfile(hardware_root / "k_mult_q30.bin", dtype="<u4").astype(np.int64).reshape(6, D_MODEL)
        self.v_mult_q30 = np.fromfile(hardware_root / "v_mult_q30.bin", dtype="<u4").astype(np.int64).reshape(6, D_MODEL)
        self.attn_proj_mult_q30 = np.fromfile(hardware_root / "attn_proj_mult_q30.bin", dtype="<u4").astype(np.int64).reshape(6, D_MODEL)
        self.ffn_mid_mult_q30 = np.fromfile(hardware_root / "ffn_mid_mult_q30.bin", dtype="<u4").astype(np.int64).reshape(6, 4 * D_MODEL)
        self.ffn_mult_q30 = np.fromfile(hardware_root / "ffn_mult_q30.bin", dtype="<u4").astype(np.int64).reshape(6, D_MODEL)

        token_module = self.modules["transformer.wte"]
        position_module = self.modules["transformer.wpe"]
        self.token_embedding_q = token_module["qweight"].detach().cpu().numpy().astype(np.int8)
        self.position_embedding_q = position_module["qweight"].detach().cpu().numpy().astype(np.int8)
        self.token_embedding_scale_q30 = np.rint(
            token_module["weight_scale"].detach().cpu().numpy().astype(np.float64) * (1 << 30)
        ).astype(np.int64)
        self.position_embedding_scale_q30 = np.rint(
            position_module["weight_scale"].detach().cpu().numpy().astype(np.float64) * (1 << 30)
        ).astype(np.int64)

    def module_arrays(self, name: str) -> tuple[np.ndarray, np.ndarray, float]:
        module = self.modules[name]
        qweight = module["qweight"].detach().cpu().numpy().astype(np.int8)
        weight_scale = module["weight_scale"].detach().cpu().numpy().astype(np.float64)
        activation_scale = float(module["activation_scale"])
        return qweight, weight_scale, activation_scale

    def embeddings(self, tokens: np.ndarray) -> tuple[np.ndarray, float]:
        token_module = self.modules["transformer.wte"]
        position_module = self.modules["transformer.wpe"]
        token_q = token_module["qweight"].detach().cpu().numpy().astype(np.int8)
        token_scale = token_module["weight_scale"].detach().cpu().numpy().astype(np.float64)
        position_q = position_module["qweight"].detach().cpu().numpy().astype(np.int8)
        position_scale = position_module["weight_scale"].detach().cpu().numpy().astype(np.float64)
        hidden = (
            token_q[tokens].astype(np.float64) * token_scale[tokens, None]
            + position_q.astype(np.float64) * position_scale[:, None]
        )
        return quant_dynamic(hidden)

    def embeddings_hardware(self, tokens: np.ndarray) -> np.ndarray:
        token_terms = (
            self.token_embedding_q[tokens].astype(np.int64)
            * self.token_embedding_scale_q30[tokens, None]
        )
        position_terms = (
            self.position_embedding_q.astype(np.int64)
            * self.position_embedding_scale_q30[:, None]
        )
        hidden_q30 = token_terms + position_terms
        max_abs = max(int(np.abs(hidden_q30).max()), 1)
        quantized = round_div_signed_array(hidden_q30 * 127, max_abs)
        return np.clip(quantized, -127, 127).astype(np.int8)

    @staticmethod
    def layernorm_to_activation(
        x_q: np.ndarray, x_scale: float, gamma: np.ndarray, activation_scale: float
    ) -> np.ndarray:
        x = x_q.astype(np.float64) * float(x_scale)
        mean = x.mean(axis=1, keepdims=True)
        variance = ((x - mean) ** 2).mean(axis=1, keepdims=True)
        normalized = (x - mean) / np.sqrt(variance + 1e-5)
        return quant_fixed(normalized * gamma.reshape(1, -1), activation_scale)

    def layernorm_hardware(self, x_q: np.ndarray, stage: int) -> np.ndarray:
        coefficients = self.layernorm_coeff_q24[stage]
        out = np.empty_like(x_q, dtype=np.int8)
        for row in range(x_q.shape[0]):
            values = x_q[row].astype(np.int64)
            total = int(values.sum())
            square_sum = int(values @ values)
            variance_numerator = D_MODEL * square_sum - total * total
            variance_numerator = max(variance_numerator, 1)
            sqrt_q16 = math.isqrt(variance_numerator << 32)
            denominator_q24 = sqrt_q16 << 8
            centered = D_MODEL * values - total
            quantized = round_div_signed_array(centered * coefficients, denominator_q24)
            out[row] = np.clip(quantized, -127, 127).astype(np.int8)
        return out

    @staticmethod
    def residual_hardware(
        a_q: np.ndarray, b_q: np.ndarray, a_mult_q30: int, b_mult_q30: int
    ) -> np.ndarray:
        scaled = (
            a_q.astype(np.int64) * int(a_mult_q30)
            + b_q.astype(np.int64) * int(b_mult_q30)
        )
        quantized = round_div_signed_array(scaled, 1 << 30)
        return np.clip(quantized, -128, 127).astype(np.int8)

    @staticmethod
    def linear_dynamic(
        x_q: np.ndarray,
        qweight: np.ndarray,
        weight_scale: np.ndarray,
        activation_scale: float,
        output_scale: float | None = None,
    ) -> tuple[np.ndarray, float, np.ndarray]:
        acc = x_q.astype(np.int32) @ qweight.astype(np.int32).T
        real = acc.astype(np.float64) * float(activation_scale) * weight_scale.reshape(1, -1)
        if output_scale is None:
            q, scale = quant_dynamic(real)
        else:
            scale = float(output_scale)
            q = quant_fixed(real, scale)
        return q, scale, real

    @staticmethod
    def linear_hardware_q30(
        x_q: np.ndarray, qweight: np.ndarray, mult_q30: np.ndarray
    ) -> tuple[np.ndarray, np.ndarray]:
        acc = x_q.astype(np.int32) @ qweight.astype(np.int32).T
        scaled = acc.astype(np.int64) * mult_q30.astype(np.int64).reshape(1, -1)
        rounded = (np.abs(scaled) + (1 << 29)) >> 30
        rounded = np.where(scaled < 0, -rounded, rounded)
        return np.clip(rounded, -128, 127).astype(np.int8), acc

    @staticmethod
    def attention(
        q_q: np.ndarray,
        q_scale: float,
        k_q: np.ndarray,
        k_scale: float,
        v_q: np.ndarray,
        v_scale: float,
    ) -> np.ndarray:
        q = q_q.astype(np.float64).reshape(SEQ_LEN, N_HEAD, HEAD_DIM)
        k = k_q.astype(np.float64).reshape(SEQ_LEN, N_HEAD, HEAD_DIM)
        v = v_q.astype(np.float64).reshape(SEQ_LEN, N_HEAD, HEAD_DIM) * float(v_scale)
        out = np.zeros((SEQ_LEN, N_HEAD, HEAD_DIM), dtype=np.float64)
        score_scale = float(q_scale) * float(k_scale) / math.sqrt(HEAD_DIM)
        for row in range(SEQ_LEN):
            for head in range(N_HEAD):
                scores = (k[: row + 1, head] @ q[row, head]) * score_scale
                scores -= float(scores.max())
                exp = np.exp(scores)
                probs = exp / float(exp.sum())
                probs_q6 = np.clip(np.rint(probs * 63.0), 0, 63)
                denominator = max(float(probs_q6.sum()), 1.0)
                out[row, head] = (probs_q6 / denominator) @ v[: row + 1, head]
        return out.reshape(SEQ_LEN, D_MODEL)

    def attention_hardware(
        self, q_q: np.ndarray, k_q: np.ndarray, v_q: np.ndarray, layer: int
    ) -> np.ndarray:
        q = q_q.astype(np.int64).reshape(SEQ_LEN, N_HEAD, HEAD_DIM)
        k = k_q.astype(np.int64).reshape(SEQ_LEN, N_HEAD, HEAD_DIM)
        v = v_q.astype(np.int64).reshape(SEQ_LEN, N_HEAD, HEAD_DIM)
        out = np.zeros((SEQ_LEN, N_HEAD, HEAD_DIM), dtype=np.int8)
        score_mult = int(self.attention_score_q16[layer])
        out_mult = int(self.attention_out_mult_q30[layer])

        for row in range(SEQ_LEN):
            for head in range(N_HEAD):
                scores = k[: row + 1, head] @ q[row, head]
                diff = int(scores.max()) - scores
                indices = np.clip((diff * score_mult + (1 << 15)) >> 16, 0, 255)
                weights = self.attention_exp_q6[indices].copy()
                weights[diff == 0] = 63
                denominator = int(weights.sum())
                weighted = weights @ v[: row + 1, head]
                divisor = denominator << 30
                scaled = weighted.astype(np.int64) * out_mult
                rounded = (np.abs(scaled) + (divisor >> 1)) // divisor
                rounded = np.where(scaled < 0, -rounded, rounded)
                out[row, head] = np.clip(rounded, -128, 127).astype(np.int8)
        return out.reshape(SEQ_LEN, D_MODEL)

    def run_block(
        self,
        tokens: np.ndarray,
        reference_dir: Path | None = None,
        fixed_scales: dict[str, float] | None = None,
    ) -> dict[str, Any]:
        if fixed_scales is None:
            x_q, x_scale = self.embeddings(tokens)
        else:
            x_q = self.embeddings_hardware(tokens)
            x_scale = float(fixed_scales["layer_00.input"])
        comparisons: dict[str, Any] = {}
        stages: dict[str, np.ndarray] = {"layer_00_input": x_q.copy()}
        scales: dict[str, float] = {"layer_00.input": x_scale}
        if reference_dir is not None:
            reference = np.frombuffer(
                (reference_dir / "layer_00_input_dynamic_i8.bin").read_bytes(), dtype=np.int8
            ).reshape(SEQ_LEN, D_MODEL)
            comparisons["layer_00.input"] = compare_i8(reference, x_q)

        for layer in range(6):
            prefix = f"layer_{layer:02d}"
            stages[f"{prefix}_input"] = x_q.copy()
            block = self.fp32_model.transformer.h[layer]
            c_attn_name = f"transformer.h.{layer}.attn.c_attn"
            qkv_weight, qkv_weight_scale, qkv_activation_scale = self.module_arrays(c_attn_name)
            if fixed_scales is None:
                ln1_q = self.layernorm_to_activation(
                    x_q,
                    x_scale,
                    block.ln_1.weight.detach().cpu().numpy().astype(np.float64),
                    qkv_activation_scale,
                )
            else:
                ln1_q = self.layernorm_hardware(x_q, layer * 2)
            stages[f"{prefix}_qkv_in"] = ln1_q.copy()
            if reference_dir is not None:
                ref = np.frombuffer(
                    (reference_dir / f"{prefix}_qkv_in_i8.bin").read_bytes(), dtype=np.int8
                ).reshape(SEQ_LEN, D_MODEL)
                comparisons[f"{prefix}.qkv_in"] = compare_i8(ref, ln1_q)

            if fixed_scales is None:
                q_q, q_scale, _ = self.linear_dynamic(
                    ln1_q, qkv_weight[:D_MODEL], qkv_weight_scale[:D_MODEL], qkv_activation_scale
                )
                k_q, k_scale, _ = self.linear_dynamic(
                    ln1_q, qkv_weight[D_MODEL : 2 * D_MODEL],
                    qkv_weight_scale[D_MODEL : 2 * D_MODEL], qkv_activation_scale
                )
                v_q, v_scale, _ = self.linear_dynamic(
                    ln1_q, qkv_weight[2 * D_MODEL :],
                    qkv_weight_scale[2 * D_MODEL :], qkv_activation_scale
                )
            else:
                q_q, _ = self.linear_hardware_q30(ln1_q, qkv_weight[:D_MODEL], self.q_mult_q30[layer])
                k_q, _ = self.linear_hardware_q30(ln1_q, qkv_weight[D_MODEL : 2 * D_MODEL], self.k_mult_q30[layer])
                v_q, _ = self.linear_hardware_q30(ln1_q, qkv_weight[2 * D_MODEL :], self.v_mult_q30[layer])
                q_scale = float(fixed_scales[f"{prefix}.q"])
                k_scale = float(fixed_scales[f"{prefix}.k"])
                v_scale = float(fixed_scales[f"{prefix}.v"])
            scales.update(
                {f"{prefix}.q": q_scale, f"{prefix}.k": k_scale, f"{prefix}.v": v_scale}
            )
            stages[f"{prefix}_q"] = q_q.copy()
            stages[f"{prefix}_k"] = k_q.copy()
            stages[f"{prefix}_v"] = v_q.copy()
            if reference_dir is not None:
                for stage, candidate in (("q", q_q), ("k", k_q), ("v", v_q)):
                    ref = np.frombuffer(
                        (reference_dir / f"{prefix}_{stage}_dynamic_i8.bin").read_bytes(),
                        dtype=np.int8,
                    ).reshape(SEQ_LEN, D_MODEL)
                    comparisons[f"{prefix}.{stage}"] = compare_i8(ref, candidate)

            proj_name = f"transformer.h.{layer}.attn.c_proj"
            proj_weight, proj_weight_scale, proj_activation_scale = self.module_arrays(proj_name)
            if fixed_scales is None:
                attn_real = self.attention(q_q, q_scale, k_q, k_scale, v_q, v_scale)
                attn_in_q = quant_fixed(attn_real, proj_activation_scale)
            else:
                attn_in_q = self.attention_hardware(q_q, k_q, v_q, layer)
            stages[f"{prefix}_attn_in"] = attn_in_q.copy()
            if fixed_scales is None:
                proj_acc = attn_in_q.astype(np.int32) @ proj_weight.astype(np.int32).T
                proj_real = (
                    proj_acc.astype(np.float64)
                    * float(proj_activation_scale)
                    * proj_weight_scale.reshape(1, -1)
                )
                proj_q, proj_scale = quant_dynamic(proj_real)
            else:
                proj_scale = float(fixed_scales[f"{prefix}.attn_proj"])
                proj_q, _ = self.linear_hardware_q30(
                    attn_in_q, proj_weight, self.attn_proj_mult_q30[layer]
                )
            scales[f"{prefix}.attn_proj"] = proj_scale
            stages[f"{prefix}_attn_proj"] = proj_q.copy()
            if reference_dir is not None:
                ref = np.frombuffer(
                    (reference_dir / f"{prefix}_attn_proj_dynamic_i8.bin").read_bytes(),
                    dtype=np.int8,
                ).reshape(SEQ_LEN, D_MODEL)
                comparisons[f"{prefix}.attn_proj"] = compare_i8(ref, proj_q)
            if fixed_scales is None:
                x_real = x_q.astype(np.float64) * float(x_scale)
                residual = x_real + proj_q.astype(np.float64) * proj_scale
                x_q, x_scale = quant_dynamic(residual)
            else:
                residual_params = self.hardware_manifest["residuals"][prefix]
                x_scale = float(fixed_scales[f"{prefix}.res1"])
                x_q = self.residual_hardware(
                    x_q,
                    proj_q,
                    int(residual_params["res1_input_mult_q30"]),
                    int(residual_params["res1_proj_mult_q30"]),
                )
            scales[f"{prefix}.res1"] = x_scale
            stages[f"{prefix}_res1"] = x_q.copy()

            fc_name = f"transformer.h.{layer}.mlp.c_fc"
            fc_weight, fc_weight_scale, fc_activation_scale = self.module_arrays(fc_name)
            if fixed_scales is None:
                ln2_q = self.layernorm_to_activation(
                    x_q,
                    x_scale,
                    block.ln_2.weight.detach().cpu().numpy().astype(np.float64),
                    fc_activation_scale,
                )
            else:
                ln2_q = self.layernorm_hardware(x_q, layer * 2 + 1)
            stages[f"{prefix}_ln2_in"] = ln2_q.copy()
            if fixed_scales is None:
                fc_acc = ln2_q.astype(np.int32) @ fc_weight.astype(np.int32).T
                fc_real = (
                    fc_acc.astype(np.float64)
                    * float(fc_activation_scale)
                    * fc_weight_scale.reshape(1, -1)
                )
                gelu_input_q = quant_fixed(fc_real, self.gelu_scale)
            else:
                gelu_input_q, _ = self.linear_hardware_q30(
                    ln2_q, fc_weight, self.ffn_mid_mult_q30[layer]
                )
            gelu_q = self.gelu_lut[gelu_input_q.astype(np.int16) + 128]
            stages[f"{prefix}_gelu_in"] = gelu_input_q.copy()
            stages[f"{prefix}_gelu"] = gelu_q.copy()
            gelu_real = gelu_q.astype(np.float64) * self.gelu_scale

            ffn_name = f"transformer.h.{layer}.mlp.c_proj"
            ffn_weight, ffn_weight_scale, ffn_activation_scale = self.module_arrays(ffn_name)
            # The PL GELU wrapper has one global-scale LUT. Feed its INT8 output
            # directly to W2 and absorb gelu_scale into the W2 requant multiplier.
            ffn_in_q = gelu_q
            if fixed_scales is None:
                ffn_acc = ffn_in_q.astype(np.int32) @ ffn_weight.astype(np.int32).T
                ffn_real = (
                    ffn_acc.astype(np.float64)
                    * float(self.gelu_scale)
                    * ffn_weight_scale.reshape(1, -1)
                )
                ffn_q, ffn_scale = quant_dynamic(ffn_real)
            else:
                ffn_scale = float(fixed_scales[f"{prefix}.ffn"])
                ffn_q, _ = self.linear_hardware_q30(
                    ffn_in_q, ffn_weight, self.ffn_mult_q30[layer]
                )
            scales[f"{prefix}.ffn"] = ffn_scale
            stages[f"{prefix}_ffn"] = ffn_q.copy()
            if reference_dir is not None:
                ref = np.frombuffer(
                    (reference_dir / f"{prefix}_ffn_dynamic_i8.bin").read_bytes(), dtype=np.int8
                ).reshape(SEQ_LEN, D_MODEL)
                comparisons[f"{prefix}.ffn"] = compare_i8(ref, ffn_q)
            if fixed_scales is None:
                x_real = x_q.astype(np.float64) * float(x_scale)
                residual = x_real + ffn_q.astype(np.float64) * ffn_scale
                x_q, x_scale = quant_dynamic(residual)
            else:
                x_scale = float(fixed_scales[f"{prefix}.final"])
                x_q = self.residual_hardware(
                    x_q,
                    ffn_q,
                    int(residual_params["final_res1_mult_q30"]),
                    int(residual_params["final_ffn_mult_q30"]),
                )
            scales[f"{prefix}.final"] = x_scale
            stages[f"{prefix}_final"] = x_q.copy()

        final_ln = self.fp32_model.transformer.ln_f
        lm_weight, lm_weight_scale, lm_activation_scale = self.module_arrays("lm_head")
        if fixed_scales is None:
            ln_f_q = self.layernorm_to_activation(
                x_q,
                x_scale,
                final_ln.weight.detach().cpu().numpy().astype(np.float64),
                lm_activation_scale,
            )
        else:
            ln_f_q = self.layernorm_hardware(x_q, 12)
        stages["ln_f"] = ln_f_q.copy()
        logits_acc = ln_f_q.astype(np.int32) @ lm_weight.astype(np.int32).T
        logits = (
            logits_acc.astype(np.float64)
            * float(lm_activation_scale)
            * lm_weight_scale.reshape(1, -1)
        )
        if fixed_scales is None:
            argmax = np.argmax(logits, axis=1).astype(np.int32)
        else:
            hardware_scores = logits_acc.astype(np.int64) * self.lm_scale_ratio_q30.reshape(1, -1)
            argmax = np.argmax(hardware_scores, axis=1).astype(np.int32)
        return {
            "argmax": argmax,
            "logits": logits,
            "final_i8": x_q,
            "final_scale": x_scale,
            "scales": scales,
            "comparisons": comparisons,
            "stage_i8": stages,
        }


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Coherent dynamic-scale bit-true INT8 simulation.")
    parser.add_argument("--prompt", default="hello world")
    parser.add_argument("--new-tokens", type=int, default=1)
    parser.add_argument("--dataset", default="shakespeare_char")
    parser.add_argument("--ckpt", type=Path, default=NANOGPT_ROOT / "out-shakespeare-char" / "ckpt.pt")
    parser.add_argument(
        "--int8-state",
        type=Path,
        default=NANOGPT_ROOT / "out-shakespeare-char" / "int8_reference" / "int8_state_dict.pt",
    )
    parser.add_argument(
        "--reference-dir",
        type=Path,
        default=REPO_ROOT / "fpga" / "nano_gpt" / "generated" / "int8_alignment" / "reference",
    )
    parser.add_argument(
        "--out-dir",
        type=Path,
        default=REPO_ROOT / "fpga" / "nano_gpt" / "generated" / "int8_alignment" / "bittrue_dynamic",
    )
    parser.add_argument("--fixed-scales", type=Path)
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    model = BitTrueModel(args.ckpt, args.int8_state, args.dataset)
    fixed_scales = None
    if args.fixed_scales is not None:
        scale_document = json.loads(args.fixed_scales.read_text(encoding="utf-8"))
        fixed_scales = {
            name: float(value) for name, value in scale_document["first_step_scales"].items()
        }
    prompt_tokens = [int(model.stoi[ch]) for ch in args.prompt]
    generated: list[int] = []
    first_result: dict[str, Any] | None = None
    for step in range(args.new_tokens):
        context = prompt_tokens + generated
        tokens = np.full((SEQ_LEN,), int(model.stoi[" "]), dtype=np.int64)
        tokens[: len(context)] = np.asarray(context, dtype=np.int64)
        result = model.run_block(
            tokens,
            args.reference_dir if step == 0 else None,
            fixed_scales=fixed_scales,
        )
        token = int(result["argmax"][len(context) - 1])
        generated.append(token)
        if first_result is None:
            first_result = result
        print(f"step={step} row={len(context)-1} token={token} char={model.itos[token]!r}")

    assert first_result is not None
    summary = {
        "kind": "bittrue_dynamic_int8",
        "prompt": args.prompt,
        "input_tokens": prompt_tokens,
        "generated_tokens": generated,
        "generated_text": "".join(model.itos[token] for token in generated),
        "full_text": args.prompt + "".join(model.itos[token] for token in generated),
        "scale_mode": "fixed" if fixed_scales is not None else "dynamic",
        "first_step_scales": first_result["scales"],
        "first_step_comparisons": first_result["comparisons"],
    }
    args.out_dir.mkdir(parents=True, exist_ok=True)
    stage_dir = args.out_dir / "stages"
    stage_dir.mkdir(parents=True, exist_ok=True)
    stage_manifest: dict[str, Any] = {}
    for name, values in first_result["stage_i8"].items():
        data = np.ascontiguousarray(values, dtype=np.int8)
        (stage_dir / f"{name}.bin").write_bytes(data.tobytes())
        (stage_dir / f"{name}.mem").write_text(
            "".join(f"{int(value) & 0xff:02x}\n" for value in data.reshape(-1)),
            encoding="ascii",
        )
        stage_manifest[name] = {"shape": list(data.shape), "elements": int(data.size)}
    (stage_dir / "manifest.json").write_text(
        json.dumps(stage_manifest, indent=2), encoding="utf-8"
    )
    out_path = args.out_dir / "summary.json"
    out_path.write_text(json.dumps(summary, indent=2), encoding="utf-8")
    print(json.dumps(summary, indent=2))


if __name__ == "__main__":
    main()
